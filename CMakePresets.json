{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 25,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "grpc-stack-debug",
      "displayName": "gRPC Stack Debug",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/grpc-stack-debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_C_COMPILER_LAUNCHER": "ccache",
        "CMAKE_CXX_COMPILER_LAUNCHER": "ccache",
        "GRPC_STACK_ROOT": "$env{HOME}/.local/toolchains/grpc-stack"
      }
    },
    {
      "name": "grpc-stack-release",
      "displayName": "gRPC Stack Release",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/grpc-stack-release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_C_COMPILER_LAUNCHER": "ccache",
        "CMAKE_CXX_COMPILER_LAUNCHER": "ccache",
        "GRPC_STACK_ROOT": "$env{HOME}/.local/toolchains/grpc-stack"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "grpc-stack-debug",
      "configurePreset": "grpc-stack-debug"
    },
    {
      "name": "grpc-stack-release",
      "configurePreset": "grpc-stack-release"
    }
  ],
  "testPresets": [
    {
      "name": "grpc-stack-debug",
      "configurePreset": "grpc-stack-debug",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
