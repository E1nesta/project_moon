MYSQL_ROOT_PASSWORD=change-me-root
MYSQL_DATABASE=game_backend
MYSQL_USER=game
MYSQL_PASSWORD=change-me-app
ACCOUNT_MYSQL_HOST=mysql
ACCOUNT_MYSQL_PORT=3306
ACCOUNT_MYSQL_USER=game
ACCOUNT_MYSQL_PASSWORD=change-me-app
ACCOUNT_MYSQL_DATABASE=account_db
PLAYER_MYSQL_HOST=mysql
PLAYER_MYSQL_PORT=3306
PLAYER_MYSQL_USER=game
PLAYER_MYSQL_PASSWORD=change-me-app
PLAYER_MYSQL_DATABASE=player_db
BATTLE_MYSQL_HOST=mysql
BATTLE_MYSQL_PORT=3306
BATTLE_MYSQL_USER=game
BATTLE_MYSQL_PASSWORD=change-me-app
BATTLE_MYSQL_DATABASE=battle_db
REDIS_PASSWORD=
REDIS_HOST=redis
REDIS_PORT=6379
ACCOUNT_REDIS_HOST=redis
ACCOUNT_REDIS_PORT=6379
ACCOUNT_REDIS_PASSWORD=
PLAYER_REDIS_HOST=redis
PLAYER_REDIS_PORT=6379
PLAYER_REDIS_PASSWORD=
BATTLE_REDIS_HOST=redis
BATTLE_REDIS_PORT=6379
BATTLE_REDIS_PASSWORD=
BATTLE_REDIS_TIMEOUT_MS=2000
PLAYER_INTERNAL_GRPC_HOST=player_internal_grpc_server
TRUSTED_GATEWAY_SHARED_SECRET=replace-with-a-long-random-secret
# gateway.crt must contain DNS:nginx, or override CLIENT_TLS_SERVER_NAME below.
CLIENT_TLS_ENABLED=true
CLIENT_TLS_CA_FILE=/etc/game_backend/tls/ca.pem
CLIENT_TLS_VERIFY_PEER=true
CLIENT_TLS_SERVER_NAME=nginx
UPSTREAM_TLS_ENABLED=true
UPSTREAM_TLS_CA_FILE=/etc/game_backend/tls/ca.pem
UPSTREAM_TLS_VERIFY_PEER=true
UPSTREAM_LOGIN_TLS_SERVER_NAME=login_server
UPSTREAM_PLAYER_TLS_SERVER_NAME=player_server
UPSTREAM_DUNGEON_TLS_SERVER_NAME=battle_server
SESSION_TTL_SECONDS=3600
PLAYER_SNAPSHOT_TTL_SECONDS=300
BATTLE_CONTEXT_TTL_SECONDS=3600
PLAYER_LOCK_TTL_SECONDS=10
DEMO_STAGE_ID=1001
DEMO_STAGE_REQUIRED_LEVEL=1
DEMO_STAGE_COST_STAMINA=10
DEMO_STAGE_MAX_STAR=3
DEMO_STAGE_GOLD_REWARD=100
DEMO_STAGE_FIRST_CLEAR_DIAMOND_REWARD=50
CLIENT_GATEWAY_HOST=nginx
