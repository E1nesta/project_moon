MYSQL_ROOT_PASSWORD=change-me-root
MYSQL_DATABASE=game_backend
MYSQL_USER=game
MYSQL_PASSWORD=change-me-app
REDIS_PASSWORD=
REDIS_HOST=redis
REDIS_PORT=6379
TRUSTED_GATEWAY_SHARED_SECRET=replace-with-a-long-random-secret
# gateway.crt must contain DNS:nginx, or override CLIENT_TLS_SERVER_NAME below.
CLIENT_TLS_ENABLED=true
CLIENT_TLS_CA_FILE=/etc/game_backend/tls/ca.pem
CLIENT_TLS_VERIFY_PEER=true
CLIENT_TLS_SERVER_NAME=nginx
UPSTREAM_TLS_ENABLED=true
UPSTREAM_TLS_CA_FILE=/etc/game_backend/tls/ca.pem
UPSTREAM_TLS_VERIFY_PEER=true
UPSTREAM_LOGIN_TLS_SERVER_NAME=login_server
UPSTREAM_PLAYER_TLS_SERVER_NAME=player_server
UPSTREAM_DUNGEON_TLS_SERVER_NAME=dungeon_server
